{
  "version": "2.0",
  "schema_note": "Governance rules v2.0 \u2014 post-construction operational rules (REGULA sprint, 2026-03-04). Updated from v1.0 to reflect operational reality: all 8 organs launched, 103 repos tracked, schema v1.0.0. Promotion rules retained as archival context; dependency and audit rules are actively enforced.",
  "dependency_rules": {
    "max_transitive_depth": 4,
    "no_circular_dependencies": true,
    "no_back_edges": true,
    "allowed_edges": [
      "ORGAN-I->ORGAN-II",
      "ORGAN-II->ORGAN-III",
      "ORGAN-I->ORGAN-III",
      "ORGAN-VII->ORGAN-I",
      "ORGAN-VII->ORGAN-II",
      "ORGAN-VII->ORGAN-III",
      "ORGAN-VII->ORGAN-V",
      "ORGAN-VII->ORGAN-VI",
      "ORGAN-IV->ORGAN-I",
      "ORGAN-IV->ORGAN-II",
      "ORGAN-IV->ORGAN-III",
      "ORGAN-IV->ORGAN-V",
      "ORGAN-IV->ORGAN-VI",
      "ORGAN-IV->ORGAN-VII",
      "ORGAN-V->ORGAN-I",
      "ORGAN-V->ORGAN-II",
      "ORGAN-V->ORGAN-III",
      "ORGAN-I->ORGAN-VI",
      "ORGAN-II->ORGAN-VI",
      "ORGAN-III->ORGAN-VI",
      "ORGAN-III->ORGAN-VII"
    ],
    "forbidden_edges": [
      "ORGAN-II->ORGAN-I",
      "ORGAN-III->ORGAN-II",
      "ORGAN-III->ORGAN-I"
    ],
    "back_edge_definition": "Within the I-II-III chain, data flows I->II->III. A back-edge is any dependency where a lower-numbered organ depends on a higher-numbered organ (e.g., I depends on II, or II depends on III). ORGAN-IV through Meta may reference any organ. ORGAN-III->VI and ORGAN-III->VII are forward edges (products feed community and distribution).",
    "restricted_organs": [
      "ORGAN-I",
      "ORGAN-II",
      "ORGAN-III"
    ],
    "restricted_orgs": [
      "organvm-i-theoria",
      "organvm-ii-poiesis",
      "organvm-iii-ergon"
    ]
  },
  "promotion_rules_note": "Construction-era promotion rules. Defined cross-organ repo promotion during the build phase (Feb 2026). Retained as archival context; not enforced by any current code path. See ADR-016.",
  "promotion_rules": {
    "promote-to-art": {
      "source_organ": "ORGAN-I",
      "destination_organ": "ORGAN-II",
      "destination_org": "organvm-ii-poiesis",
      "conditions": [
        "Source repo has documentation_status != EMPTY",
        "Source repo has at least 1 documented use case in README",
        "Source repo has implementation_status in [PROTOTYPE, PRODUCTION]",
        "No unresolved critical alerts for source repo"
      ],
      "naming": "art-from--{source_repo_name}",
      "status": "archival"
    },
    "promote-to-commerce": {
      "source_organ": "ORGAN-II",
      "destination_organ": "ORGAN-III",
      "destination_org": "organvm-iii-ergon",
      "conditions": [
        "Source repo has documentation_status != EMPTY",
        "Source repo has at least 3 documented use cases",
        "Pricing model defined in source docs or issue",
        "Support model documented"
      ],
      "naming": "{source_repo_name}",
      "status": "archival"
    },
    "promote-to-public-process": {
      "source_organ": "ANY",
      "destination_organ": "ORGAN-V",
      "destination_org": "organvm-v-logos",
      "conditions": [
        "Source repo has documentation_status != EMPTY",
        "Essay outline provided in promotion issue"
      ],
      "naming": "essay-from--{source_repo_name}",
      "status": "archival"
    }
  },
  "state_machine": {
    "states": [
      "INCUBATOR",
      "LOCAL",
      "CANDIDATE",
      "PUBLIC_PROCESS",
      "GRADUATED",
      "ARCHIVED"
    ],
    "transitions": {
      "INCUBATOR": [
        "LOCAL",
        "ARCHIVED"
      ],
      "LOCAL": [
        "CANDIDATE",
        "ARCHIVED"
      ],
      "CANDIDATE": [
        "PUBLIC_PROCESS",
        "LOCAL",
        "ARCHIVED"
      ],
      "PUBLIC_PROCESS": [
        "GRADUATED",
        "CANDIDATE",
        "ARCHIVED"
      ],
      "GRADUATED": [
        "ARCHIVED"
      ],
      "ARCHIVED": []
    },
    "promotion_criteria": {
      "INCUBATOR_to_LOCAL": [
        "Epistemic Boundary: strict JSON Schema or YAML configuration defined",
        "DAG Check: Upstream/Downstream edges explicitly declared in seed.yaml",
        "Neurological Handshake: Interface Contract (Webhook/MCP) established",
        "14-Day TTL: Graduation within 14 days of project creation"
      ],
      "CANDIDATE_to_PUBLIC_PROCESS": [
        "ci_workflow is not null",
        "implementation_status is ACTIVE",
        "README exists and passes portfolio gate"
      ],
      "PUBLIC_PROCESS_to_GRADUATED": [
        "All CANDIDATE criteria met",
        "platinum_status is true",
        "Stranger test or peer review completed",
        "No critical audit findings"
      ]
    }
  },
  "audit_thresholds": {
    "critical": {
      "missing_readme": true,
      "circular_dependency": true,
      "back_edge_violation": true,
      "organ_has_zero_repos": true
    },
    "warning": {
      "stale_repo_days": 90,
      "missing_changelog": true,
      "missing_ci_workflow": true,
      "missing_badges": true,
      "essay_count_below": 10,
      "missing_seed_yaml": true
    }
  },
  "internalized_principles": [
    "biz.ship_speed",
    "practice.idempotency",
    "antipattern.big_bang",
    "practice.feature_flags",
    "phil.scylla_charybdis",
    "logical_consistency",
    "quality_over_quantity"
  ],
  "organ_requirements": {
    "ORGAN-I": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_tests": false,
      "requires_seed_yaml": true
    },
    "ORGAN-II": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_tests": false,
      "requires_seed_yaml": true
    },
    "ORGAN-III": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_tests": false,
      "requires_revenue_fields": true,
      "requires_seed_yaml": true
    },
    "ORGAN-IV": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_registry": true,
      "requires_seed_yaml": true
    },
    "ORGAN-V": {
      "min_repos": 1,
      "requires_readme": true,
      "min_essays": 10,
      "requires_seed_yaml": true
    },
    "ORGAN-VI": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_seed_yaml": true
    },
    "ORGAN-VII": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_seed_yaml": true
    },
    "META-ORGANVM": {
      "min_repos": 1,
      "requires_readme": true,
      "requires_seed_yaml": true
    }
  },
  "schema_version": "1"
}
